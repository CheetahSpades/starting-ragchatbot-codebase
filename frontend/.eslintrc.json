{
    "env": {
        "browser": true,
        "es2022": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
    },
    "globals": {
        "marked": "readonly"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-console": "warn",
        "eqeqeq": "error",
        "no-var": "error",
        "prefer-const": "warn"
    }
}
